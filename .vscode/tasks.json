{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Frontend: npm start",
			"type": "shell",
			"command": "npm start",
			"options": {
				"cwd": "${workspaceFolder}/Frontend"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"label": "Backend: spring-boot run",
			"type": "shell",
			"command": ".\\mvnw.cmd spring-boot:run",
			"options": {
				"cwd": "${workspaceFolder}/Backend"
			},
			"isBackground": true,
			"problemMatcher": []
		}
	]
}